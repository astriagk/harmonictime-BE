// ============================================================================
//  Harmoniv Time V2 — Watch Selling Marketplace (Multi-Product Catalog)
//  MongoDB Database Design (DBML)
// ----------------------------------------------------------------------------
//  This is the authoritative V2 schema. It incorporates all V1 tables and
//  extends the Catalog domain to support any product type beyond watches.
//
//  Key V2 changes vs V1:
//    1. Category is the dynamic discriminator — Products.CategoryID drives which
//       attribute set (form) applies. No hard-coded product types.
//    2. ProductDetails        — fixed watch columns replaced by generic `attributes`
//    3. ProductAttributeSchemas (NEW) — admin-managed, ONE schema per Category.
//       Each attribute descriptor carries full form-render + validation + buyer
//       display metadata, so forms and product pages are 100% data-driven.
//    4. AttributeOptions (NEW) — unified enum lookup (scoped by Category +
//       attribute key), replaces the 5 watch-only tables.
//    5. DialColors / Movements / StrapMaterials / CaseMaterials / WatchMarkers
//                             — DEPRECATED; data migrated to AttributeOptions
//
//  All other tables (Identity, Shopping, Commerce, Settlement, Reviews) are
//  identical to V1.
//
//  Tip: paste into https://dbdiagram.io  or run
//       npx @dbml/cli validate spec/v2/harmoniv_time_v2.dbml
// ============================================================================

Project harmoniv_time_v2 {
  database_type: 'MongoDB'
  Note: '''
    # Harmoniv Time V2

    A fully dynamic, category-agnostic marketplace. V1 was watch-only; V2 lets
    an admin create any Category and define its attribute schema — no product
    types are hard-coded in the schema or the code. Choosing a Category drives
    the seller form (which fields, widgets, validation) and the buyer display
    (which fields show on the card vs detail page, units, filters). Sellers fill
    ProductDetails.attributes per the Category's schema. Enum values live in a
    single AttributeOptions collection scoped by Category.

    ## Domains
    - **Identity**    : Users, Roles, UserRoles, Address
    - **Catalog**     : Products (CategoryID = dynamic discriminator) ·
                        ProductDescription · ProductDetails (attributes map) ·
                        ProductImages · DeliveryReturns ·
                        ProductAttributeSchemas (NEW, one per Category) ·
                        AttributeOptions (NEW) · plus unchanged lookups
                        (Brands, Collections, Categories, Recipients,
                        DeliveryOptions)
    - **Shopping**    : Cart, Wishlist, RecentlyViewedProducts
    - **Commerce**    : Checkout, CheckoutItems, Sales, Offers, Payments, Shipments
    - **Settlement**  : SellerEarnings, SellerBankAccounts, Withdrawals
    - **Reviews**     : Reviews, UserReviews

    ## Removed (V1 watch-only lookup tables)
    DialColors, Movements, StrapMaterials, CaseMaterials, WatchMarkers no longer
    exist in V2 — their values live in AttributeOptions under the "Watch"
    category. A one-time V1→V2 migration copies the rows across, then drops the
    old tables.
  '''
}

// ============================================================================
//  DOMAIN: IDENTITY  (unchanged from V1)
// ============================================================================

Table Users {
  _id           objectid    [pk]
  email         string      [unique, not null]
  password      string      [not null, note: 'bcrypt hash']
  phone         string      [null]
  status        string      [null, note: 'active (default) | blocked | suspended']
  dateCreated   timestamp   [note: 'set to new Date() on register']
  otp           string      [null, note: 'sha256 hash of OTP, transient']
  otpExpiry     timestamp   [null, note: 'OTP valid 10 min']
}

Table Roles {
  _id        objectid   [pk]
  RoleID     int        [unique, not null, note: '1=admin, 3=customer']
  RoleName   string     [unique, not null]
}

Table UserRoles {
  _id          objectid   [pk]
  UserRoleID   int
  UserID       objectid   [not null]
  RoleID       int        [not null, note: 'references Roles.RoleID (int)']

  Note: 'On register a UserRoles row {RoleID:3} is auto-created for the new user.'
}

Table Address {
  _id            objectid   [pk]
  UserID         objectid   [not null]
  FirstName      string     [not null]
  LastName       string     [not null]
  Country        string     [not null]
  AddressLine1   string     [not null]
  AddressLine2   string     [null]
  City           string     [not null]
  State          string     [not null]
  PostalCode     string     [not null]
  Phone          string     [not null]
  orderNotes     string     [null]
  IsDefault      boolean    [default: false]
}

// ============================================================================
//  DOMAIN: CATALOG — core product  (V2 CHANGES: Products + ProductDetails)
// ============================================================================

Table Products {
  _id              objectid    [pk]
  UserID           objectid    [not null, note: 'seller']
  ProductName      string      [not null]
  BrandID          objectid    [not null]
  CollectionID     objectid    [null]
  CategoryID       objectid    [not null, note: '''
    V2 dynamic discriminator. Resolves to exactly one ProductAttributeSchemas
    (by CategoryID), whose Attributes[] define the seller form and buyer view.
    Admin-created — no hard-coded product types. Existing watch products are
    migrated to the seeded "Watch" category during migration.
  ''']
  RecipientID      objectid    [null]
  DeliveryOptionID objectid    [null, note: 'global, cross-cutting — applies to any category (not a per-category attribute)']
  Price            decimal     [not null]
  Quantity         int         [not null, default: 1, note: 'total stock; RemainingQuantity = Quantity - SoldCount (derived)']
  OfferID          objectid    [null]
  IsAvailable      boolean     [default: true]
  DateListed       timestamp
  IsPriceInclusiveOfTax   boolean   [default: false]
  ApprovalStatus   string      [not null, default: 'Pending', note: 'Pending | Approved | Rejected']
  ApprovalNote     string      [null]
  ApprovedBy       objectid    [null]
  ApprovedAt       timestamp   [null]
}

Table ProductDescription {
  _id                 objectid    [pk]
  ProductID           objectid    [not null]
  Title               string
  Content             string
  AdditionalDetails   string
  CreatedAt           timestamp

  Note: 'One-to-one with Products. Unchanged from V1.'
}

Table ProductDetails {
  _id          objectid   [pk]
  ProductID    objectid   [not null]
  attributes   object     [not null, note: '''
    V2: generic key-value map replacing fixed watch columns.
    Shape is defined by ProductAttributeSchemas for the product''s CategoryID.

    Enum-ref keys store an ObjectId → AttributeOptions._id.
    Free-text / numeric keys store the value inline.

    Watch example (backward-compatible with V1 data after migration):
    {
      "dialColorId":            ObjectId,   // was DialColorID
      "movementId":             ObjectId,   // was MovementID
      "strapMaterialId":        ObjectId,   // was StrapMaterialID
      "caseMaterialId":         ObjectId,   // was CaseMaterialID
      "watchMarkerId":          ObjectId,   // was WatchMarkersID
      "diameter":               "40mm",
      "waterResistant":         "100m",
      "manufacturerProductNumber": "AB-1234",
      "guarantee":              "2 years"
    }

    Jewelry example:
    {
      "gemstoneId":    ObjectId,
      "metalTypeId":   ObjectId,
      "carat":         "18k",
      "ringSize":      "7",
      "weight":        "5g"
    }

    Enum refs inside attributes are resolved in application code via a single
    $in lookup against AttributeOptions after reading the CategoryID''s
    ProductAttributeSchemas to identify which keys are ObjectId refs.
  ''']

  Note: 'One-to-one with Products (joined by ProductID).'
}

Table ProductImages {
  _id          objectid   [pk]
  ProductID    objectid   [not null]
  ImageURL     string     [not null, note: 'hosted on ImgBB']
  key          string     [null, note: 'ImgBB delete key']
  IsPrimary    boolean    [default: false]
  AltText      string     [null]
  mediaType    string     [null, note: 'image | video']

  Note: 'One Products → many ProductImages. Unchanged from V1.'
}

Table DeliveryReturns {
  _id                   objectid   [pk]
  ProductID             objectid   [not null]
  DeliveryInformation   string
  ReturnsPolicy         string
  CreatedAt             timestamp

  Note: 'One-to-one with Products. Unchanged from V1.'
}

// ============================================================================
//  DOMAIN: CATALOG — V2 new tables
// ============================================================================

Table ProductAttributeSchemas {
  _id            objectid    [pk]
  CategoryID     objectid    [unique, not null, note: 'one schema per Category — the dynamic discriminator']
  DisplayName    string      [not null, note: 'UI label shown to sellers, e.g. "Watches"']
  Attributes     array       [not null, note: '''
    Ordered list of attribute descriptors. Each element carries EVERYTHING the
    seller form and the buyer view need, so rendering is 100% data-driven:
    {
      // identity
      key:           string,    // camelCase — matches key in ProductDetails.attributes
      label:         string,    // seller/buyer-facing label
      type:          string,    // "enum" | "multi-enum" | "text" | "number" | "boolean" | "date"
      refCollection: string,    // only for enum/multi-enum: "AttributeOptions"

      // form rendering
      inputWidget:   string,    // "select" | "radio" | "checkbox" | "textarea" | "text" | "number" | "toggle"
      placeholder:   string,
      helpText:      string,
      defaultValue:  any,
      group:         string,    // section header to group fields in the form
      displayOrder:  number,    // order within the form / detail page

      // validation (data-driven — no code branching)
      required:      boolean,
      min:           number,    // number/date
      max:           number,
      minLength:     number,    // text
      maxLength:     number,
      pattern:       string,    // regex
      unit:          string,    // shown after value, e.g. "mm", "g"

      // buyer-facing display control
      showOnCard:    boolean,   // render on listing card
      showOnDetail:  boolean,   // render on product detail page
      isFilterable:  boolean,   // expose as a facet filter on listing pages
      isSearchable:  boolean,   // include in text search

      // conditional fields (dynamic forms)
      visibleWhen:   object     // e.g. { key: "hasBattery", equals: true } | null
    }

    Admin creates/edits these via POST|PUT /api/admin/product-attribute-schemas.
    The Attributes array drives form rendering, server-side validation, buyer
    display, and enrichment resolution (identifying which attributes.* keys hold
    ObjectId refs vs inline values).
  ''']
  CreatedAt      timestamp
  UpdatedAt      timestamp
}

Table AttributeOptions {
  _id            objectid    [pk]
  CategoryID     objectid    [not null, note: 'scopes the option to a Category']
  AttributeKey   string      [not null, note: 'matches key in ProductAttributeSchemas.Attributes, e.g. dialColorId']
  Value          string      [not null, note: 'display value, e.g. "Black", "Swiss ETA 2824"']
  DisplayOrder   int         [default: 0, note: 'order within the dropdown']
  IsActive       boolean     [default: true, note: 'hide from new selections without deleting history']
  Meta           object      [null, note: 'optional render hints, e.g. { hex: "#000", icon: "..." } for a color swatch']
  CreatedAt      timestamp

  Note: '''
    Unique index on (CategoryID, AttributeKey, Value).
    Unified replacement for the five V1 watch-only tables.

    V1 migration (into the seeded "Watch" category):
      DialColors.*      → AttributeKey="dialColorId"
      Movements.*       → AttributeKey="movementId"
      StrapMaterials.*  → AttributeKey="strapMaterialId"
      CaseMaterials.*   → AttributeKey="caseMaterialId"
      WatchMarkers.*    → AttributeKey="watchMarkerId"

    After all ProductDetails rows are migrated, the five V1 tables are dropped.
  '''
}

// ============================================================================
//  DOMAIN: CATALOG — lookup / reference tables  (unchanged from V1)
// ============================================================================

Table Brands {
  _id         objectid   [pk]
  BrandName   string     [unique, not null]
}

Table Collections {
  _id              objectid   [pk]
  BrandID          objectid   [not null]
  CollectionName   string     [unique, not null]
}

Table Categories {
  _id            objectid   [pk]
  CategoryName   string     [unique, not null]
}

Table Recipients {
  _id             objectid   [pk]
  RecipientName   string     [unique, not null]
}

Table DeliveryOptions {
  _id                  objectid   [pk]
  DeliveryOptionName   string     [unique, not null]

  Note: 'Global, cross-cutting lookup — same options for every category. Referenced directly by Products.DeliveryOptionID, NOT via the per-category attributes map.'
}

// ----------------------------------------------------------------------------
//  REMOVED in V2 — the V1 watch-only lookup tables DialColors / Movements /
//  StrapMaterials / CaseMaterials / WatchMarkers no longer exist. Their values
//  now live in AttributeOptions under the seeded "Watch" category, keyed by
//  dialColorId / movementId / strapMaterialId / caseMaterialId / watchMarkerId.
//  (One-time V1→V2 migration copies the rows across, then drops the tables.)
// ----------------------------------------------------------------------------

// ============================================================================
//  DOMAIN: SHOPPING  (unchanged from V1)
// ============================================================================

Table Cart {
  _id          objectid   [pk]
  UserID       objectid   [not null]
  ProductID    objectid   [not null]
  Quantity     int        [null, default: 1]

  Note: 'Unique (UserID, ProductID).'
}

Table Wishlist {
  _id          objectid   [pk]
  UserID       objectid   [not null]
  ProductID    objectid   [not null]
}

Table RecentlyViewedProducts {
  _id          objectid   [pk]
  UserID       objectid   [not null]
  ProductID    objectid   [not null]
  ViewedAt     timestamp  [not null]

  Note: 'Sorted newest-first (ViewedAt desc).'
}

// ============================================================================
//  DOMAIN: COMMERCE  (unchanged from V1)
// ============================================================================

Table Checkout {
  _id              objectid    [pk]
  UserID           objectid    [not null]
  AddressID        objectid    [not null]
  TotalAmount      decimal     [not null]
  PaymentStatus    string      [not null, note: 'Pending | Paid | Failed']
  DeliveryStatus   string      [not null, note: 'Processing | Shipped | Delivered']
  CheckoutDate     timestamp   [not null]
  ProductIDs       string      [note: 'ARRAY of Product ObjectIds']

  Note: 'Acts as the ORDER record (no separate Orders collection).'
}

Table CheckoutItems {
  _id           objectid    [pk]
  CheckoutID    objectid    [not null]
  ProductIDs    string      [note: 'ARRAY of Product ObjectIds']
  Price         decimal     [not null]
  Quantity      int         [null]
}

Table Sales {
  _id              objectid    [pk]
  BuyerID          objectid    [not null]
  SellerID         objectid    [not null]
  ProductID        objectid    [not null]
  OfferID          objectid    [null]
  SaleDate         timestamp   [not null]
  SalePrice        decimal     [not null]
  DiscountAmount   decimal     [default: 0]
  FinalPrice       decimal     [not null]
}

Table Offers {
  _id                  objectid    [pk]
  OfferName            string      [unique, not null]
  Description          string      [null]
  DiscountPercentage   decimal     [not null]
  StartDate            timestamp   [not null]
  EndDate              timestamp   [not null]
  IsActive             boolean     [default: true]
}

Table Payments {
  _id                 objectid    [pk]
  CheckoutID          objectid    [not null]
  UserID              objectid    [not null]
  Amount              decimal     [not null]
  Currency            string      [default: 'INR']
  RazorpayOrderID     string      [null]
  RazorpayPaymentID   string      [null]
  RazorpaySignature   string      [null]
  PaymentMethod       string      [null]
  PaymentStatus       string      [not null, note: 'Created | Verified | Failed | RefundPending']
  Receipt             string      [null]
  PaidAt              timestamp   [null]
  CreatedAt           timestamp
}

Table Shipments {
  _id                 objectid    [pk]
  CheckoutID          objectid    [not null]
  SellerID            objectid    [not null]
  Courier             string      [not null]
  TrackingNumber      string      [not null]
  TrackingURL         string      [null]
  ShipmentStatus      string      [not null, note: 'Pending | Shipped | InTransit | OutForDelivery | Delivered']
  ShippedAt           timestamp   [null]
  EstimatedDelivery   timestamp   [null]
  DeliveredAt         timestamp   [null]
  Notes               string      [null]
  CreatedAt           timestamp
}

// ============================================================================
//  DOMAIN: SETTLEMENT  (unchanged from V1)
// ============================================================================

Table SellerEarnings {
  _id                objectid    [pk]
  SellerID           objectid    [not null]
  CheckoutID         objectid    [not null]
  ProductID          objectid    [not null]
  GrossAmount        decimal     [not null]
  CommissionRate     decimal     [not null]
  CommissionAmount   decimal     [not null]
  NetAmount          decimal     [not null]
  Status             string      [not null, note: 'Pending | Available | Requested | Settled']
  SaleDate           timestamp   [not null]
  AvailableAt        timestamp   [null]
  WithdrawalID       objectid    [null]
  CreatedAt          timestamp
}

Table SellerBankAccounts {
  _id                 objectid    [pk]
  SellerID            objectid    [not null]
  AccountHolderName   string      [not null]
  AccountNumber       string      [not null]
  IFSC                string      [not null]
  BankName            string      [not null]
  IsDefault           boolean     [default: false]
  CreatedAt           timestamp
}

Table Withdrawals {
  _id            objectid    [pk]
  SellerID       objectid    [not null]
  BankAccountID  objectid    [not null]
  BankSnapshot   string      [null]
  Amount         decimal     [not null]
  EarningIDs     string      [note: 'ARRAY of SellerEarnings._id']
  Status         string      [not null, note: 'Pending | Approved | Paid | Rejected']
  Reference      string      [null]
  Notes          string      [null]
  RequestedAt    timestamp   [not null]
  ProcessedAt    timestamp   [null]
  ProcessedBy    objectid    [null]
}

// ============================================================================
//  DOMAIN: REVIEWS  (unchanged from V1)
// ============================================================================

Table Reviews {
  _id         objectid    [pk]
  ProductID   objectid    [not null]
  Rating      int         [not null, note: '1–5 stars']
  Name        string      [not null]
  Email       string      [not null]
  Comment     string      [not null]
  CreatedAt   timestamp
}

Table UserReviews {
  _id         objectid    [pk]
  UserID      objectid    [not null, note: 'seller being reviewed']
  ProductID   objectid    [not null]
  Rating      int         [not null, note: '1–5 stars']
  Subject     string      [not null]
  Name        string      [null]
  Email       string      [not null]
  Comment     string      [not null]
  CreatedAt   timestamp
}

// ============================================================================
//  RELATIONSHIPS
// ============================================================================

// --- Identity ---
Ref: UserRoles.UserID > Users._id
Ref: UserRoles.RoleID > Roles.RoleID
Ref: Address.UserID  > Users._id

// --- Catalog: product → lookups ---
Ref: Products.UserID       > Users._id
Ref: Products.BrandID      > Brands._id
Ref: Products.CollectionID > Collections._id
Ref: Products.CategoryID   > Categories._id
Ref: Products.RecipientID  > Recipients._id
Ref: Products.DeliveryOptionID > DeliveryOptions._id
Ref: Products.OfferID      > Offers._id
Ref: Products.ApprovedBy   > Users._id
Ref: Collections.BrandID   > Brands._id

// --- Catalog: V2 dynamic category-driven type system ---
Ref: ProductAttributeSchemas.CategoryID  - Categories._id   // one schema per category
Ref: AttributeOptions.CategoryID         > Categories._id   // options scoped by category
// Products.CategoryID > Categories._id is declared below; it also selects the schema.
// ProductDetails.attributes.* → AttributeOptions._id resolved in application code

// --- Catalog: product 1:1 / 1:N satellites ---
Ref: ProductDescription.ProductID - Products._id
Ref: ProductDetails.ProductID     - Products._id
Ref: DeliveryReturns.ProductID    - Products._id
Ref: ProductImages.ProductID      > Products._id

// --- Shopping ---
Ref: Cart.UserID                        > Users._id
Ref: Cart.ProductID                     > Products._id
Ref: Wishlist.UserID                    > Users._id
Ref: Wishlist.ProductID                 > Products._id
Ref: RecentlyViewedProducts.UserID      > Users._id
Ref: RecentlyViewedProducts.ProductID   > Products._id

// --- Commerce ---
Ref: Checkout.UserID            > Users._id
Ref: Checkout.AddressID         > Address._id
Ref: CheckoutItems.CheckoutID   > Checkout._id
Ref: Sales.BuyerID              > Users._id
Ref: Sales.SellerID             > Users._id
Ref: Sales.ProductID            > Products._id
Ref: Sales.OfferID              > Offers._id
Ref: Payments.CheckoutID        > Checkout._id
Ref: Payments.UserID            > Users._id
Ref: Shipments.CheckoutID       > Checkout._id
Ref: Shipments.SellerID         > Users._id

// --- Reviews ---
Ref: Reviews.ProductID      > Products._id
Ref: UserReviews.UserID     > Users._id
Ref: UserReviews.ProductID  > Products._id

// --- Settlement ---
Ref: SellerEarnings.SellerID      > Users._id
Ref: SellerEarnings.CheckoutID    > Checkout._id
Ref: SellerEarnings.ProductID     > Products._id
Ref: SellerEarnings.WithdrawalID  > Withdrawals._id
Ref: SellerBankAccounts.SellerID  > Users._id
Ref: Withdrawals.SellerID         > Users._id
Ref: Withdrawals.BankAccountID    > SellerBankAccounts._id
Ref: Withdrawals.ProcessedBy      > Users._id

// ============================================================================
//  TABLE GROUPS
// ============================================================================

TableGroup Identity {
  Users
  Roles
  UserRoles
  Address
}

TableGroup Catalog {
  Products
  ProductDescription
  ProductDetails
  ProductImages
  DeliveryReturns
  ProductAttributeSchemas
  AttributeOptions
  Brands
  Collections
  Categories
  Recipients
  DeliveryOptions
}

TableGroup Shopping {
  Cart
  Wishlist
  RecentlyViewedProducts
}

TableGroup Commerce {
  Checkout
  CheckoutItems
  Sales
  Offers
  Payments
  Shipments
}

TableGroup Settlement {
  SellerEarnings
  SellerBankAccounts
  Withdrawals
}

TableGroup Reviews {
  Reviews
  UserReviews
}
