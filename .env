MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>
DB_NAME=ecommerce
PORT=5000
LOG_LEVEL=debug
JWT_SECRET=your_jwt_secret_here
EMAIL_USER=your_email@gmail.com
CONTACT_RECIPIENT=your_email@gmail.com
EMAIL_PASS=your app password here
IMGBB_API_KEY=your_imgbb_api_key

AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET_NAME=your_s3_bucket_name

# Razorpay Payment Gateway Configuration (Development/Testing)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Razorpay X current account number — required for penny-drop bank verification
RAZORPAY_ACCOUNT_NUMBER=your_razorpay_account_number

# AWS S3 Storage Configuration
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_storage_access_key
STORAGE_SECRET_KEY=your_storage_secret_key
STORAGE_BUCKET_NAME=your_storage_bucket_name

# Seller Settlement
# PLATFORM_COMMISSION_RATE: platform's cut of each sale (0.1 = 10%)
# PAYOUT_HOLD_DAYS: days after delivery before a sale's amount is withdrawable
PLATFORM_COMMISSION_RATE=0.1
PAYOUT_HOLD_DAYS=0
